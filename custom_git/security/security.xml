<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="group_git_admin" model="res.groups">
        <field name="name">Git Administrator</field>
        <field name="comment">
            Can add repositories, sync branches, sync commits from GitHub.
        </field>
    </record>

    <record id="group_git_viewer" model="res.groups">
        <field name="name">Git Viewer</field>
        <field name="comment">
            Can view repositories, branches, and commits in read-only mode.
        </field>
    </record>

</odoo>