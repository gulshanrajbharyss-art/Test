<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Commit File List -->
    <record id="view_custom_git_commit_file_list" model="ir.ui.view">
        <field name="name">custom.git.commit.file.list</field>
        <field name="model">custom.git.commit.file</field>
        <field name="arch" type="xml">
            <list string="Changed Files"
                  decoration-success="status == 'added'"
                  decoration-danger="status == 'removed'"
                  decoration-warning="status == 'modified'">
                <field name="filename"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'added'"
                       decoration-danger="status == 'removed'"
                       decoration-info="status == 'modified'"
                       decoration-warning="status == 'renamed'"/>
                <field name="additions" sum="Total"/>
                <field name="deletions" sum="Total"/>
                <field name="changes"/>
            </list>
        </field>
    </record>

    <!-- Commit File Search -->
    <record id="view_custom_git_commit_file_search" model="ir.ui.view">
        <field name="name">custom.git.commit.file.search</field>
        <field name="model">custom.git.commit.file</field>
        <field name="arch" type="xml">
            <search string="Search Files">
                <field name="filename"/>
                <separator/>
                <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
            </search>
        </field>
    </record>

    <!-- Commit File Action -->
    <record id="action_custom_git_commit_file" model="ir.actions.act_window">
        <field name="name">Changed Files</field>
        <field name="res_model">custom.git.commit.file</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_custom_git_commit_file_search"/>
    </record>

</odoo>