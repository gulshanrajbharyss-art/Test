<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LOCAL OPS: REPOSITORY FORM EXTENSION ==================== -->

    <!-- Inherit the existing repository form and inject the Local Operations section -->
    <record id="view_git_repository_local_ops_inherit" model="ir.ui.view">
        <field name="name">custom.git.repository.form.local.ops</field>
        <field name="model">custom.git.repository</field>
        <field name="inherit_id" ref="custom_git.view_custom_git_repository_form"/>
        <field name="arch" type="xml">

           <xpath expr="//field[@name='company_id']" position="after">        <field name="local_path"
                       placeholder="/opt/odoo/myproject"
                       groups="custom_git.group_git_admin"/>
                <field name="current_branch"
                       readonly="1"
                       widget="badge"
                       decoration-info="current_branch != '—'"
                       groups="custom_git.group_git_admin"/>
                <field name="has_conflict"
                       readonly="1"
                       widget="boolean_toggle"
                       invisible="not has_conflict"
                       groups="custom_git.group_git_admin"/>
            </xpath>

            <!-- Add stat button for quick status check -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_git_status"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-terminal"
                        groups="custom_git.group_git_admin"
                        invisible="not local_path">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Git Status</span>
                    </div>
                </button>
            </xpath>

            <!-- Add Local Git Operations header buttons -->
            <xpath expr="//header" position="inside">
                <button name="action_git_status"
                        type="object"
                        string="Status"
                        class="btn-secondary"
                        icon="fa-info-circle"
                        groups="custom_git.group_git_admin"
                        invisible="not local_path"/>
                <button name="action_git_log"
                        type="object"
                        string="Log"
                        class="btn-secondary"
                        icon="fa-history"
                        groups="custom_git.group_git_admin"
                        invisible="not local_path"/>
                <button name="action_git_fetch"
                        type="object"
                        string="Fetch"
                        class="btn-secondary"
                        icon="fa-cloud-download"
                        groups="custom_git.group_git_admin"
                        invisible="not local_path"/>
                <button name="action_git_pull"
                        type="object"
                        string="Pull"
                        class="btn-primary"
                        icon="fa-arrow-down"
                        groups="custom_git.group_git_admin"
                        invisible="not local_path"/>
                <button name="action_git_push"
                        type="object"
                        string="Push"
                        class="btn-primary"
                        icon="fa-arrow-up"
                        groups="custom_git.group_git_admin"
                        invisible="not local_path"/>
            </xpath>

            <!-- Append a new notebook page for Local Git Operations -->
            <xpath expr="//notebook" position="inside">
                <page string="Local Git Operations"
                      name="local_git_ops"
                      groups="custom_git.group_git_admin"
                      invisible="not local_path">

                    <!-- Row 1: Code / Staging -->
                    <div class="row mt-2">
                        <div class="col-12 col-md-6">
                            <h5 class="text-muted">
                                <i class="fa fa-code"/> Working Tree
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button name="action_git_status"
                                        type="object"
                                        string="Git Status"
                                        class="btn btn-outline-secondary btn-sm"
                                        icon="fa-info-circle"/>
                                <button name="action_git_diff"
                                        type="object"
                                        string="Git Diff"
                                        class="btn btn-outline-secondary btn-sm"
                                        icon="fa-exchange"/>
                                <button name="action_git_log"
                                        type="object"
                                        string="Git Log"
                                        class="btn btn-outline-secondary btn-sm"
                                        icon="fa-history"/>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <h5 class="text-muted">
                                <i class="fa fa-check-square-o"/> Staging &amp; Commit
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button name="action_git_add"
                                        type="object"
                                        string="Git Add"
                                        class="btn btn-outline-primary btn-sm"
                                        icon="fa-plus"/>
                                <button name="action_git_commit"
                                        type="object"
                                        string="Git Commit"
                                        class="btn btn-outline-primary btn-sm"
                                        icon="fa-save"/>
                            </div>
                        </div>
                    </div>

                    <hr/>

                    <!-- Row 2: Remote -->
                    <div class="row mt-2">
                        <div class="col-12 col-md-6">
                            <h5 class="text-muted">
                                <i class="fa fa-cloud"/> Remote
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button name="action_git_fetch"
                                        type="object"
                                        string="Git Fetch"
                                        class="btn btn-outline-info btn-sm"
                                        icon="fa-cloud-download"/>
                                <button name="action_git_pull"
                                        type="object"
                                        string="Git Pull"
                                        class="btn btn-outline-info btn-sm"
                                        icon="fa-arrow-down"/>
                                <button name="action_git_push"
                                        type="object"
                                        string="Git Push"
                                        class="btn btn-outline-info btn-sm"
                                        icon="fa-arrow-up"/>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <h5 class="text-muted">
                                <i class="fa fa-code-fork"/> Branches
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button name="action_git_checkout_branch"
                                        type="object"
                                        string="Checkout Branch"
                                        class="btn btn-outline-warning btn-sm"
                                        icon="fa-code-fork"/>
                            </div>
                        </div>
                    </div>

                    <hr/>

                    <!-- Row 3: Stash -->
                    <div class="row mt-2">
                        <div class="col-12 col-md-6">
                            <h5 class="text-muted">
                                <i class="fa fa-inbox"/> Stash
                            </h5>
                            <div class="d-flex flex-wrap gap-2">
                                <button name="action_git_stash"
                                        type="object"
                                        string="Git Stash"
                                        class="btn btn-outline-secondary btn-sm"
                                        icon="fa-inbox"/>
                                <button name="action_git_stash_pop"
                                        type="object"
                                        string="Stash Pop"
                                        class="btn btn-outline-secondary btn-sm"
                                        icon="fa-sign-out"/>
                                <button name="action_git_stash_list"
                                        type="object"
                                        string="Stash List"
                                        class="btn btn-outline-secondary btn-sm"
                                        icon="fa-list"/>
                            </div>
                        </div>
                    </div>

                    <hr/>

                    <!-- Last Operation Output -->
                    <div class="row mt-3" invisible="not last_operation_output">
                        <div class="col-12">
                            <h5 class="text-muted">
                                <i class="fa fa-terminal"/> Last Operation:
                                <field name="last_operation" readonly="1"
                                       class="fw-bold text-dark"/>
                            </h5>
                            <div class="alert"
                                 style="background:#1e1e1e;border-radius:6px;padding:12px;">
                                <field name="last_operation_output"
                                       readonly="1"
                                       widget="text"
                                       style="font-family:monospace;font-size:12px;
                                              color:#d4d4d4;white-space:pre-wrap;
                                              background:transparent;border:none;
                                              width:100%;"/>
                            </div>
                        </div>
                    </div>

                    <!-- Conflict Warning Banner -->
                    <div class="alert alert-danger mt-2"
                         invisible="not has_conflict">
                        <i class="fa fa-exclamation-triangle"/>
                        <strong> Merge Conflict Detected!</strong>
                        Resolve conflicts manually, then use
                        <em>Git Add</em> + <em>Git Commit</em> to complete.
                    </div>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
