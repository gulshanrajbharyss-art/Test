<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====================== COMMIT VIEWS ====================== -->

    <!-- Commit List -->
    <record id="view_custom_git_commit_list" model="ir.ui.view">
        <field name="name">custom.git.commit.list</field>
        <field name="model">custom.git.commit</field>
        <field name="arch" type="xml">
            <list string="Commits"
                  decoration-success="additions > deletions"
                  decoration-danger="deletions > additions">
                <field name="short_sha"/>
                <field name="branch_id" invisible="context.get('search_default_branch_id')"/>
                <field name="author_name"/>
                <field name="author_login"/>
                <field name="commit_message" string="Message" widget="text"/>
                <field name="commit_date" widget="date"/>
                <field name="files_changed"/>
                <field name="additions" sum="Total"/>
                <field name="deletions" sum="Total"/>
                <field name="repository_id" invisible="context.get('search_default_repository_id')"/>
            </list>
        </field>
    </record>

    <!-- Commit Form -->
    <record id="view_custom_git_commit_form" model="ir.ui.view">
        <field name="name">custom.git.commit.form</field>
        <field name="model">custom.git.commit</field>
        <field name="arch" type="xml">
            <form string="Commit" create="false" edit="false" delete="false">
                <header>
                    <button name="action_view_on_github"
                            type="object"
                            string="View on GitHub"
                            class="btn-primary"
                            icon="fa-external-link"/>
                </header>
                <sheet>
                    <group>
                        <group string="Commit Info">
                            <field name="sha" readonly="1"/>
                            <field name="short_sha" readonly="1"/>
                            <field name="repository_id" readonly="1"/>
                            <field name="branch_id" readonly="1"/>
                            <field name="commit_date" readonly="1"/>
                            <field name="url" widget="url" readonly="1"/>
                        </group>
                        <group string="Who Committed">
                            <field name="author_name" readonly="1"/>
                            <field name="author_login" readonly="1"/>
                            <field name="author_email" readonly="1"/>
                        </group>
                    </group>
                    <group string="What Changed">
                        <field name="commit_message" readonly="1" nolabel="1" placeholder="Commit message..."/>
                        <group>
                            <field name="files_changed" readonly="1"/>
                            <field name="additions" readonly="1"/>
                            <field name="deletions" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Changed Files" name="changed_files">
                            <field name="changed_file_ids" nolabel="1" readonly="1">
                                <list decoration-success="status == 'added'"
                                      decoration-danger="status == 'removed'"
                                      decoration-warning="status == 'modified'">
                                    <field name="filename"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'added'"
                                           decoration-danger="status == 'removed'"
                                           decoration-info="status == 'modified'"
                                           decoration-warning="status == 'renamed'"/>
                                    <field name="additions" sum="Total"/>
                                    <field name="deletions" sum="Total"/>
                                    <field name="changes"/>
                                </list>
                                <form string="File Details">
                                    <group>
                                        <group>
                                            <field name="filename" readonly="1"/>
                                            <field name="status" readonly="1"/>
                                            <field name="previous_filename" readonly="1"
                                                   invisible="status != 'renamed'"/>
                                        </group>
                                        <group>
                                            <field name="additions" readonly="1"/>
                                            <field name="deletions" readonly="1"/>
                                            <field name="changes" readonly="1"/>
                                        </group>
                                    </group>
                                    <group string="Patch">
                                        <field name="patch" readonly="1" nolabel="1"
                                               widget="text" class="oe_monospace"/>
                                    </group>
                                    <group>
                                        <field name="raw_url" widget="url" readonly="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Commit Search -->
    <record id="view_custom_git_commit_search" model="ir.ui.view">
        <field name="name">custom.git.commit.search</field>
        <field name="model">custom.git.commit</field>
        <field name="arch" type="xml">
            <search string="Search Commits">
                <field name="short_sha"/>
                <field name="author_name"/>
                <field name="author_login"/>
                <field name="commit_message"/>
                <field name="branch_id"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('commit_date', '>=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_week" string="This Week"
                        domain="[('commit_date', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_month" string="This Month"
                        domain="[('commit_date', '>=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="group_repository" string="Repository"
                        context="{'group_by': 'repository_id'}"/>
                <filter name="group_branch" string="Branch"
                        context="{'group_by': 'branch_id'}"/>
                <filter name="group_author" string="Author"
                        context="{'group_by': 'author_name'}"/>
                <filter name="group_date" string="Date"
                        context="{'group_by': 'commit_date:day'}"/>
            </search>
        </field>
    </record>

    <!-- Commit Action -->
    <record id="action_custom_git_commit" model="ir.actions.act_window">
        <field name="name">Commits</field>
        <field name="res_model">custom.git.commit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_custom_git_commit_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No commits synced yet
            </p>
            <p>
                Open a branch and click <b>Sync Commits from GitHub</b>
                to fetch all commits for that branch.
            </p>
        </field>
    </record>

</odoo>