<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====================== REPOSITORY VIEWS ====================== -->

    <!-- Repository List -->
    <record id="view_custom_git_repository_list" model="ir.ui.view">
        <field name="name">custom.git.repository.list</field>
        <field name="model">custom.git.repository</field>
        <field name="arch" type="xml">
            <list string="Repositories">
                <field name="name"/>
                <field name="full_name"/>
                <field name="branch_count"/>
                <field name="commit_count"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <!-- Repository Form -->
    <record id="view_custom_git_repository_form" model="ir.ui.view">
        <field name="name">custom.git.repository.form</field>
        <field name="model">custom.git.repository</field>
        <field name="arch" type="xml">
            <form string="Git Repository">
                <header>
                    <button name="action_sync_branches"
                            type="object"
                            string="Sync Branches"
                            class="btn-warning"
                            icon="fa-code-fork"
                            groups="custom_git.group_git_admin"/>
                    <button name="action_sync_all_commits"
                            type="object"
                            string="Sync All Branch Commits"
                            class="btn-primary"
                            icon="fa-refresh"
                            groups="custom_git.group_git_admin"/>
                    <button name="action_open_github"
                            type="object"
                            string="Open on GitHub"
                            icon="fa-external-link"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" placeholder="e.g. octocat/Hello-World"/></h1>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_branches" type="object" class="oe_stat_button" icon="fa-code-fork">
                            <field name="branch_count" string="Branches" widget="statinfo"/>
                        </button>
                        <button name="action_view_commits" type="object" class="oe_stat_button" icon="fa-code">
                            <field name="commit_count" string="Commits" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group string="Repository">
                            <field name="name" placeholder="Short name"/>
                            <field name="full_name" placeholder="owner/repo-name"/>
                            <field name="github_url" widget="url" readonly="1"/>
                        </group>
                        <group string="Settings">
                            <field name="github_token" password="True"
                                   groups="base.group_system"
                                   placeholder="Leave empty to use system token"/>
                            <field name="last_sync" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches" name="branches">
                            <field name="branch_ids" nolabel="1">
                                <list editable="bottom" decoration-info="commit_count > 0">
                                    <field name="name"/>
                                    <field name="commit_count"/>
                                    <field name="last_commit_sha"/>
                                    <field name="last_commit_date" widget="date"/>
                                    <field name="last_sync" widget="date" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Recent Commits" name="commits">
                            <field name="commit_ids" nolabel="1">
                                <list decoration-success="additions > deletions" decoration-danger="deletions > additions">
                                    <field name="short_sha"/>
                                    <field name="branch_id"/>
                                    <field name="author_name"/>
                                    <field name="author_login"/>
                                    <field name="commit_message" widget="text"/>
                                    <field name="commit_date" widget="date"/>
                                    <field name="files_changed"/>
                                    <field name="additions"/>
                                    <field name="deletions"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Repository Search -->
    <record id="view_custom_git_repository_search" model="ir.ui.view">
        <field name="name">custom.git.repository.search</field>
        <field name="model">custom.git.repository</field>
        <field name="arch" type="xml">
            <search string="Search Repositories">
                <field name="name"/>
                <field name="full_name"/>
            </search>
        </field>
    </record>

    <!-- Repository Action -->
    <record id="action_custom_git_repository" model="ir.actions.act_window">
        <field name="name">Repositories</field>
        <field name="res_model">custom.git.repository</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_custom_git_repository_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No repositories yet
            </p>
            <p>
                Click <b>New</b> to add a GitHub repository.
                Enter the full name like <b>owner/repo</b>,
                then click <b>Sync Branches</b> to load branches from GitHub.
            </p>
        </field>
    </record>

</odoo>